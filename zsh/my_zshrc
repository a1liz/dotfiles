alias proxy='_proxy(){
  host=$1

  # 1. 环境变量
  export http_proxy=http://$host:7890
  export https_proxy=http://$host:7890
  export all_proxy=socks5://$host:7890

  # 2. git config
  git config --global http.proxy "http://$host:7890"
  git config --global https.proxy "http://$host:7890"

  # 3. 写入 ~/.ssh/config
  mkdir -p ~/.ssh
  chmod 700 ~/.ssh

  # 先删除旧的 github.com 配置
  sed -i "/^Host github.com$/,/^$/d" ~/.ssh/config 2>/dev/null

  # 写入新的
  cat >> ~/.ssh/config <<EOF
Host github.com
  HostName ssh.github.com
  User git
  Port 443
  ProxyCommand nc -x $host:7890 -X connect %h %p

EOF

  echo "✅ proxy set to $host:7890 (git + ssh)"
}; _proxy'
alias proxyme='proxy $(who am I | grep -Pom 1 "[0-9.]{7,15}"); echo "Set proxy with $http_proxy"'
