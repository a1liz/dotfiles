# alias unproxy='export http_proxy="" https_proxy="" all_proxy=""; git config --global http.proxy ""; git config --global https.proxy ""; '
alias echoproxy='_echoproxy(){
  echo "🌐 env:"
  echo "  http_proxy  = ${http_proxy:-<empty>}"
  echo "  https_proxy = ${https_proxy:-<empty>}"
  echo "  all_proxy   = ${all_proxy:-<empty>}"

  echo ""
  echo "🧩 git:"
  echo "  http.proxy  = $(git config --global --get http.proxy || echo "<unset>")"
  echo "  https.proxy = $(git config --global --get https.proxy || echo "<unset>")"

  echo ""
  echo "🔐 ssh (github.com):"
  awk "/^Host github.com$/,/^$/" ~/.ssh/config 2>/dev/null || echo "  <no config>"
}; _echoproxy'
alias unproxy='_unproxy(){
  # 1. 清理环境变量
  unset http_proxy https_proxy all_proxy

  # 2. 清理 git proxy
  git config --global --unset http.proxy 2>/dev/null
  git config --global --unset https.proxy 2>/dev/null

  # 3. 清理 ssh github proxy
  if [ -f ~/.ssh/config ]; then
    sed -i "/^Host github.com$/,/^$/d" ~/.ssh/config
  fi

  echo "❌ proxy cleared (env + git + ssh)"
}; _unproxy'
